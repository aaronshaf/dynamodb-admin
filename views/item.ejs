<!DOCTYPE html>
<html lang='en' data-theme="<%= theme %>">
<head>
  <%- include('partials/head') %>
  <%- include('partials/ace-deps') %>
  <%- include('partials/bootstrap-deps') %>
  <script src='<%= basePath %>/assets/vendor/lossless-json/lossless-json.js'></script>
  <%- include('partials/head-tail') %>
</head>
<body class='container-fluid d-flex flex-column'>
  <header>
    <%
      const breadcrumb = [
        {
          href: basePath + '/',
          text: 'Tables',
        },
        {
          href: `${basePath}/tables/${encodeURIComponent(TableName)}`,
          text: Table.TableName,
          badge: Table.ItemCount,
        },
      ]

      // Item is an attribute map; extract the display value for the breadcrumb
      const idAttr = Item.id
      if (idAttr) {
        breadcrumb.push({ text: idAttr.S || idAttr.N || 'Item' })
      } else {
        breadcrumb.push({ text: 'Item' })
      }
    %>
    <%- include('partials/breadcrumb', { breadcrumb }) %>
    <%- include('partials/error-container') %>
  </header>

  <main class='flex-fill d-flex flex-column'>
    <nav class="d-flex align-items-center">
      <script>
      /* global LosslessJSON, $ */

      // ---- Editor view mode state ----
      // 'json' = clean JSON view (default), 'attribute' = DynamoDB attribute map view
      let viewMode = 'json'

      // ---- Attribute map <-> JSON conversion ----

      /**
       * Convert a DynamoDB attribute map to a plain JS-like object for display.
       * Numbers are emitted as LosslessNumber so LosslessJSON.stringify renders
       * them as raw numeric literals without precision loss.
       */
      function attrMapToJsonValue(attr) {
        if (attr == null) return null
        if (attr.S !== undefined) return attr.S
        if (attr.N !== undefined) return new LosslessJSON.LosslessNumber(attr.N)
        if (attr.BOOL !== undefined) return attr.BOOL
        if (attr.NULL) return null
        if (attr.L) return attr.L.map(attrMapToJsonValue)
        if (attr.M) {
          const result = {}
          for (const [k, v] of Object.entries(attr.M)) {
            result[k] = attrMapToJsonValue(v)
          }
          return result
        }
        if (attr.SS) return attr.SS
        if (attr.NS) return attr.NS.map(n => new LosslessJSON.LosslessNumber(n))
        if (attr.BS) return attr.BS
        if (attr.B) return attr.B
        return attr
      }

      function attrMapToJsonString(attrMap) {
        const obj = {}
        for (const [k, v] of Object.entries(attrMap)) {
          obj[k] = attrMapToJsonValue(v)
        }
        return LosslessJSON.stringify(obj, null, 2)
      }

      /**
       * Convert a parsed JSON value (from LosslessJSON.parse) back to a
       * DynamoDB attribute map value.
       */
      function jsonValueToAttrMap(value) {
        if (value === null || value === undefined) return { NULL: true }
        if (LosslessJSON.isLosslessNumber(value)) return { N: value.toString() }
        if (typeof value === 'number') return { N: String(value) }
        if (typeof value === 'boolean') return { BOOL: value }
        if (typeof value === 'string') return { S: value }
        if (Array.isArray(value)) return { L: value.map(jsonValueToAttrMap) }
        if (typeof value === 'object') {
          const m = {}
          for (const [k, v] of Object.entries(value)) {
            m[k] = jsonValueToAttrMap(v)
          }
          return { M: m }
        }
        return { S: String(value) }
      }

      function jsonStringToAttrMap(jsonStr) {
        const parsed = LosslessJSON.parse(jsonStr)
        const result = {}
        for (const [k, v] of Object.entries(parsed)) {
          result[k] = jsonValueToAttrMap(v)
        }
        return result
      }

      // ---- Get current editor content as attribute map (regardless of view mode) ----

      function getEditorAsAttrMap() {
        const text = editor.getValue()
        if (viewMode === 'attribute') {
          return JSON.parse(text)
        } else {
          return jsonStringToAttrMap(text)
        }
      }

      // ---- Set editor content from an attribute map ----

      function setEditorFromAttrMap(attrMap) {
        if (viewMode === 'json') {
          editor.setValue(attrMapToJsonString(attrMap), -1)
        } else {
          editor.setValue(JSON.stringify(attrMap, null, 2), -1)
        }
      }

      // ---- Extract scalar value from attribute ----

      function attrValue(attr) {
        if (!attr || typeof attr !== 'object') return attr
        return attr.S || attr.N || attr.BOOL || attr.NULL || JSON.stringify(attr)
      }

      // ---- Toggle handler (wired up after DOM ready, see bottom of file) ----

      function handleToggleView(checked) {
        try {
          if (checked) {
            // Switch to attribute map view
            const attrMap = getEditorAsAttrMap()
            viewMode = 'attribute'
            editor.setValue(JSON.stringify(attrMap, null, 2), -1)
          } else {
            // Switch to JSON view
            const attrMap = JSON.parse(editor.getValue())
            viewMode = 'json'
            editor.setValue(attrMapToJsonString(attrMap), -1)
          }
        } catch (e) {
          handleError('Cannot switch view: ' + e.message)
        }
        editor.focus()
      }

      // ---- Save handler ----

      function handleEditClick () {
        const saveButton = document.getElementById('saveButton')

        let body
        try {
          body = JSON.stringify(getEditorAsAttrMap())
        } catch (e) {
          handleError('Invalid JSON: ' + e.message)
          return
        }

        fetch(document.location.pathname, {
          method: 'put',
          headers: {
            'Content-Type': 'application/json'
          },
          body: body
        }).then(async (response) => {
          if (response.ok) {
            return response.json()
          } else {
            const responseText = await response.text()
            throw new Error(JSON.parse(responseText).message)
          }
        }).then((json) => {
          if (document.location.pathname.endsWith('/add-item')) {
            const urlPart1 = document.location.pathname.replace('/add-item', '')
            const param = encodeURIComponent(Object.values(json).map(attrValue).join(','))

            window.location = `${urlPart1}/items/${param}`
            return
          }
          setEditorFromAttrMap(json)
          editor.focus()
          saveButton.classList.remove('btn-primary')
          saveButton.classList.add('btn-success')
          setTimeout(() => {
            saveButton.classList.add('btn-primary')
            saveButton.classList.remove('btn-success')
          }, 2000)
        }).catch((error) => {
          editor.focus()
          saveButton.classList.remove('btn-primary')
          saveButton.classList.add('btn-warning')
          setTimeout(() => {
            saveButton.classList.add('btn-primary')
            saveButton.classList.remove('btn-warning')
          }, 2000)
          handleError(error.message)
        })
      }

      // ---- Delete handler ----

      function handleDeleteClick (event) {
        event.preventDefault()
        fetch(document.location.pathname, {
          method: 'delete'
        }).then(async (response) => {
          if (response.ok) {
            window.location = '<%= basePath %>/tables/<%= encodeURIComponent(TableName) %>'
          } else {
            const responseText = await response.text()
            throw new Error(JSON.parse(responseText).message)
          }
        }).catch((error) => {
          handleError(error.message)
        })
      }
      </script>

      <button
        class='btn btn-primary'
        id='saveButton'
        onclick='handleEditClick()'
        type='button'
      >
        Save
      </button>

      <% if (!isNew) { %>
        <button
          class='btn btn-danger ml-1'
          onclick='handleDeleteClick(event)'
          type='button'
        >
          Delete
        </button>
      <% } %>

      <div class="ml-auto">
        DynamoDB Format <input id="view-mode-toggle" type="checkbox" data-toggle="toggle" data-size="xs" data-onstyle="secondary">
      </div>
    </nav>
    <article
        id="documentWrapper"
        class="flex-fill"
        style='position: relative; margin-top: 16px; width: 100%; height: 100%'>
      <div id='documentTextarea' style='
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;'></div>
      <script>
      const editor = ace.edit("documentTextarea")
      editor.resize()
      editor.getSession().setMode("ace/mode/json")
      editor.setTheme("ace/theme/monokai")
      editor.setFontSize(14)

      // Initialize editor with JSON view of the attribute map
      const initialAttrMap = <%- JSON.stringify(Item) %>;
      setEditorFromAttrMap(initialAttrMap)
      editor.focus()

      // Wire up the view mode toggle
      $(function () {
        $('#view-mode-toggle').change(function () {
          handleToggleView(this.checked)
        })
      })
      </script>
    </article>
  </main>
</body>
</html>
