{
  "name": "dynamodb-admin",
  "version": "5.3.3",
  "packageManager": "pnpm@11.5.3",
  "description": "GUI for DynamoDB. Useful for local development.",
  "bin": {
    "dynamodb-admin": "dist/dynamodb-admin.js"
  },
  "main": "dist/backend.js",
  "types": "dist/lib/backend.d.ts",
  "files": [
    "dist",
    "public",
    "views"
  ],
  "scripts": {
    "build": "tsc && rimraf dist && rollup --config rollup.config.ts --configPlugin typescript",
    "build:watch": "rollup --config rollup.config.ts --configPlugin typescript --watch",
    "start": "nodemon dist/dynamodb-admin.js",
    "lint": "eslint .",
    "fix": "eslint --fix .",
    "test": "vitest run",
    "prepare": "husky",
    "preversion": "pnpm build",
    "postversion": "git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aaronshaf/dynamodb-admin.git"
  },
  "keywords": [
    "DynamoDB",
    "Dynamo"
  ],
  "author": "Aaron Shafovaloff <aaronshaf@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aaronshaf/dynamodb-viewer/issues"
  },
  "homepage": "https://github.com/aaronshaf/dynamodb-viewer#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1064.0",
    "@aws-sdk/lib-dynamodb": "^3.1064.0",
    "argparse": "^2.0.1",
    "body-parser": "^1.20.5",
    "cookie-parser": "^1.4.7",
    "ejs": "^3.1.10",
    "errorhandler": "^1.5.2",
    "express": "^4.22.2",
    "lodash.pickby": "^4.6.0",
    "open": "^10.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/argparse": "^2.0.17",
    "@types/body-parser": "^1.19.6",
    "@types/cli-color": "^2.0.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/errorhandler": "^1.5.3",
    "@types/express": "^5.0.6",
    "@types/lodash.pickby": "^4.6.9",
    "@types/node": "^20.19.42",
    "concurrently": "^9.2.1",
    "eslint": "10.4.1",
    "eslint-config-rchl-base": "^2.0.4",
    "eslint-config-rchl-typescript": "^3.0.3",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "rollup": "^4.61.1",
    "rollup-plugin-bundle-esm": "^0.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
